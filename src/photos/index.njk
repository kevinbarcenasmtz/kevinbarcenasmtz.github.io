---
layout: base.njk
title: Photos
description: Photos by me.
permalink: /photos/
---

<h1 class="name-heading">Photos<img src="/drop.svg" class="name-icon name-icon--photos" alt=""></h1>

{% if collections.photos.length == 0 %}
  <p class="empty">Nothing here yet.</p>
{% else %}
<div class="photo-grid" id="photo-grid">
  {% for photo in collections.photos %}
    {% if photo.data.image %}
      <div
        class="photo-slot"
        data-src="{{ photo.data.image }}"
        {% if photo.data.alt %}aria-label="{{ photo.data.alt }}"{% endif %}
      ></div>
    {% endif %}
  {% endfor %}
</div>
{% endif %}

<script src="/js/photos.js"></script>
