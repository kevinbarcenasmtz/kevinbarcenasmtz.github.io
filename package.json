{
  "name": "kevinbarcenasmtz.github.io",
  "private": true,
  "type": "module",
  "scripts": {
    "validate": "html-validate index.html 404.html",
    "format": "prettier --write index.html 404.html style.css README.md",
    "format:check": "prettier --check index.html 404.html style.css README.md",
    "check": "npm run validate && npm run format:check"
  },
  "devDependencies": {
    "html-validate": "11.4.0",
    "prettier": "3.8.3"
  }
}
